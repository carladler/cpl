entry fn ENTRY(args){
	if Length(args) == 0{
		print "This test requires command line arguments";
		return 0;
	}

	a=2;
	if a==1{
		print "a=1";
	}else{
		foreach x args{
			print "x=".x;
		}
		print "a!=";

		i=0;
		while i<4{
			if i==1{
				print "blat! ". i;
			}
			i=i+1;
			print "bloop ".i;
		}

		b=23;
		if b==24{
			print "b=23";
		}else{
			print "b!=23";
		}
	}
	print "end";
}

