entry foo{
	a = 1;
	b = 2;

	if a==1 || b==2{
		print "okay1";
	}

	if a<2 && b<3{
		print "okay2";
	}

	if a==0 || b < 3{
		print "okay3";
	}

	if a==0 || b==0{
		print "not okay4";
	}else{
		print "okay4";
	}

	if a==1 && b==3{
		print "not okay5";
	}else{
		print "okay5";
	}

	if a+b > 2 && a*b > 0{
		print "okay6";
	}

}